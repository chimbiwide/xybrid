{
  "model_id": "neutts-nano-q4",
  "version": "1.0",
  "description": "NeuTTS Nano (120M) - Codec-based TTS with discrete audio generation. Q4 quantized GGUF backbone + NeuCodec ONNX decoder.",
  "execution_template": {
    "type": "Gguf",
    "model_file": "neutts-nano-Q4_0.gguf",
    "context_length": 2048,
    "generation_params": {
      "max_tokens": 2048,
      "temperature": 1.0,
      "top_p": 1.0,
      "top_k": 50,
      "repetition_penalty": 1.0,
      "stop_sequences": ["<|SPEECH_GENERATION_END|>"]
    }
  },
  "preprocessing": [
    {
      "type": "PhonemeRaw",
      "backend": "OpenPhonemizer",
      "language": "en-us"
    }
  ],
  "postprocessing": [
    {
      "type": "CodecDecode",
      "decoder_model": "neucodec-decoder-int8.onnx",
      "sample_rate": 24000,
      "token_pattern": "<\\|speech_(\\d+)\\|>",
      "apply_postprocessing": true
    }
  ],
  "files": [
    "neutts-nano-Q4_0.gguf",
    "neucodec-decoder-int8.onnx",
    "open-phonemizer.onnx",
    "dictionary.json",
    "voices/jo.bin",
    "voices/jo.txt",
    "voices/dave.bin",
    "voices/dave.txt"
  ],
  "voices": {
    "format": "precomputed_codes",
    "codes_dir": "voices/",
    "codes_pattern": "{voice_id}.bin",
    "transcript_dir": "voices/",
    "transcript_pattern": "{voice_id}.txt",
    "default": "jo",
    "catalog": [
      {
        "id": "jo",
        "name": "Jo",
        "gender": "female",
        "language": "en-US",
        "style": "neutral"
      },
      {
        "id": "dave",
        "name": "Dave",
        "gender": "male",
        "language": "en-US",
        "style": "neutral"
      }
    ]
  },
  "metadata": {
    "task": "text-to-speech",
    "architecture": "neutts",
    "backend": "llamacpp",
    "parameters": 120000000,
    "license": "MIT",
    "sample_rate": 24000,
    "family": "NeuTTS",
    "codec_model": "neucodec",
    "codec_tokens": 4096,
    "ram_minimum_mb": 256,
    "ram_recommended_mb": 512
  }
}
